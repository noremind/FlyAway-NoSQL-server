# HTTP server port.
PORT=3001

# Preferred MongoDB connection string.
# Use either MONGODB_URI or MONGODB_USER/MONGODB_PASSWORD fallback variables.
MONGODB_URI=your_mongodb_connection_string

# Fallback MongoDB credentials if MONGODB_URI is not provided.
MONGODB_USER=your_mongodb_user
MONGODB_PASSWORD=your_mongodb_password

# JWT signing secret. Use a long random value in real environments.
JWT_SECRET=your_jwt_secret

# Optional Vercel Blob token for file uploads.
BLOB_READ_WRITE_TOKEN=your_blob_read_write_token
