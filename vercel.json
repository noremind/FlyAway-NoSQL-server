{
	"version": 2,
	"builds": [
		{
			"src": "server.js",
			"use": "@vercel/node"
		},
		{
			"src": "public/",
			"use": "@vercel/static"
		}
	],
	"routes": [
		{
			"src": "/(.+)",
			"dest": "public/$1"
		},
		{
			"src": "/storage/(.*)",
			"dest": "/images/avatar/$1"
		},
		{
			"src": "/(.*)",
			"dest": "server.js"
		}
	]
}
